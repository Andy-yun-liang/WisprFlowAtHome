{
  "name": "whispr-at-home",
  "version": "1.0.0",
  "description": "Personal push-to-talk speech-to-text with auto-paste",
  "main": "out/main/index.js",
  "author": "WhisprAtHome",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "make": "npm run build && electron-builder --config electron-builder.config.ts",
    "postinstall": "electron-rebuild -f -w uiohook-napi,keytar"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "electron-store": "^8.2.0",
    "keytar": "^7.9.0",
    "node-record-lpcm16": "^1.0.1",
    "openai": "^4.52.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@types/keytar": "^4.4.2",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "canvas": "^3.2.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
